# ─── Pipeline Configuration ──────────────────────────────────────────────────

# Cities to track (lat,lon pairs — Open-Meteo uses coordinates)
CITIES=Casablanca,Paris,London,New York,Tokyo

# Coordinates mapping (used internally by extractor)
# Format: city:lat:lon separated by |
CITY_COORDS=Casablanca:33.5731:-7.5898|Paris:48.8566:2.3522|London:51.5074:-0.1278|New York:40.7128:-74.0060|Tokyo:35.6762:139.6503

# Database
DATABASE_URL=sqlite:///data/weather_warehouse.db

# Schedule: run pipeline every N minutes
PIPELINE_INTERVAL_MINUTES=60

# Data retention: keep last N days of raw files
RAW_DATA_RETENTION_DAYS=7

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
